# Server-only. Never prefix secrets with VITE_.
DATABASE_URL=postgres://pneunexus:pneunexus@localhost:5432/pneunexus
SESSION_SECRET=replace-with-at-least-32-random-bytes
APP_ORIGIN=http://localhost:5173
LOG_IP_ADDRESSES=false
AI_DIAGNOSTIC_MODEL=gpt-4o-mini
# Optional for direct OpenAI access. Netlify AI Gateway injects the provider
# configuration automatically at function runtime. Never use a VITE_ prefix.
# OPENAI_API_KEY=replace-with-a-rotated-server-only-key

# Public, non-secret display configuration only.
VITE_APP_ENV=development
